{
  "name": "tray-wakeword-app",
  "version": "1.0.0",
  "description": "Cross-platform system tray app with offline wake word detection",
  "main": "main.js",
  "scripts": {
    "postinstall": "node scripts/patch-electron-mac-mic.js",
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "release:mac": "npm run build:mac && ./scripts/upload-release-mac.sh"
  },
  "build": {
    "appId": "com.trilogy.wakeword",
    "productName": "WakeWordApp",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "assets/**/*",
      "models/**/*"
    ],
    "extraResources": [
      {
        "from": "models/",
        "to": "models/",
        "filter": [
          "**/*.ppn"
        ]
      },
      {
        "from": "assets/",
        "to": "assets/",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": ".env",
        "to": ".env"
      }
    ],
    "asarUnpack": [
      "node_modules/@picovoice/**/*"
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "mac": {
      "target": "zip",
      "icon": "assets/icon.png",
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "This app needs microphone access to listen for the wake word."
      }
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icon.png"
    }
  },
  "author": {
    "name": "Trilogy",
    "email": "dev@trilogy.com"
  },
  "license": "MIT",
  "devDependencies": {
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "@picovoice/porcupine-node": "^4.0.2",
    "@picovoice/pvrecorder-node": "^1.2.8"
  }
}
